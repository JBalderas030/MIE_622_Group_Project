### 6. Joining the data files

Coordinate reference system (CRS) used is WGS 84.

```{r}

# Bind the rows
# Our coordinate reference system (CRS) is the same WGS 84, therefore we can join them
baxtel_joined <- rbind(baxtel_df_default, baxtel_df_12_unique, baxtel_df_6_unique, baxtel_df_lw_48, baxtel_df_all_regions)

nrow(baxtel_joined)  # count of rows
ncol(baxtel_joined)

# Check if there are any duplicate rows
  # Standardize
  tmp_joined <- baxtel_joined |>
  st_zm(drop = TRUE, what = "ZM") |>
  st_make_valid() |>
  st_set_precision(1e6)
  
  # Hash
  tmp_joined <- tmp_joined |>
    mutate(
    geom_hash = vapply(
      st_as_binary(st_geometry(tmp_joined)),
      digest,
      FUN.VALUE = character(1),
      algo = "xxhash64"
      )
    )
  
  # Check for any duplicate groups
  dup_check_joined_df <- tmp_joined |>
  count(
    gid, name, county, state, full_fips,
    current_mw, construction_mw, planned_mw,
    current_plus_construction_mw, total_mw,
    geom_hash,
    sort = TRUE
    ) |>
  filter(n>1)
  
  dup_check_joined_df # view if there are any duplicate groups
  
  
  # Let's remove the duplicate groups
  # number of extra rows to be removed
    sum(dup_check_joined_df$n - 1)
    
  # number of extra rows to be removed
    sum(dup_check_joined_df$n - 1)
  
  # largest duplicate group sizes
  dup_check_joined_df |>
    arrange(desc(n)) |> # arrange in descending order so the biggest duplicate counts are at the top
    select(n) |> # keep only the 'n' column...'n' is the count of rows that share the same signature in our dataset
    head(10) # display the first 10 rows of that result
  
  # remove the duplicate rows by keeping one row per signature
  baxtel_joined_clean <- tmp_joined |>
  distinct(
    gid, name, county, state, full_fips,
    current_mw, construction_mw, planned_mw,
    current_plus_construction_mw, total_mw,
    geom_hash,
    .keep_all = TRUE
  ) |>
  select(-geom_hash) # remove the geom_hash column
  
  baxtel_joined_clean # view the cleaned dataset for file 6
  
  
  baxtel_joined_clean # view the clean dataset
# Our final dataset is 618 x 11

  # Sanity checks
  # 1. Do the counts reconcile?
      c(
        before = nrow(baxtel_joined),
        after  = nrow(baxtel_joined_clean),
        removed = nrow(baxtel_joined) - nrow(baxtel_joined_clean)
      )
# rows before is 1809, rows after is 618, and rows removed are 1191. Therefore, our counts reconcile.
  # 2. Is the removed count exactly what the duplicate groups imply?    
      expected_removed <- sum(dup_check_joined_df$n - 1)
      expected_removed
      # our expected removed is 1191
      
      actual_removed <- nrow(baxtel_joined) - nrow(baxtel_joined_clean)
      actual_removed
      # our actual removed is 1191
      
      # Therefore our removed count is exactly what the duplicate groups imply.

