The data is highly skewed to the right, let's do a log-scale histogram chart

```{r}
# We plot log10(total_mw) so smaller counties are visible

county_totals_log <- county_totals |>
  filter(total_mw > 0) |> # a filter to avoid log(0)
  mutate(log10_total_mw = log10(total_mw)) # create a new column for the total_mw in log format

ggplot(data = county_totals_log, 
       aes( x = log10_total_mw)
       ) +
  geom_histogram(bins = 40, boundary = 0, fill = "steelblue", color = "white") + # bins = number of bars; can be adjusted to taste
  scale_x_continuous(
    name = "Total MW (log10 scale)", # Label axis in original MW units (10^x)
    breaks = log10(c(0.1, 1, 10, 100, 1000, 10000)),
    labels = scales::comma(c(0.1, 1, 10, 100, 1000, 10000)))+
  labs(
    title = "Distribution of Total Data Center Energy Demand Across Counties",
    subtitle = "Histogram",
