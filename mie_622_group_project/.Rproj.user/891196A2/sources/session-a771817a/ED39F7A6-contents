#### i) Stacked Chart showing the top 20 counties by total energy demand for data centers

```{r}
# Build all energy totals from the baxtel joined clean data to create a readable county label for analysis
    county_totals <- baxtel_joined_clean |> # county total is the sum of facility level (mw) energy demand within that county
      st_drop_geometry()|>
      group_by(full_fips)|>
      summarise(
      name  = first(name),
      county = first(county),
      state  = first(state),
      current_mw = max(current_mw, na.rm = TRUE),
      construction_mw = max(construction_mw, na.rm = TRUE),
      planned_mw = max(planned_mw, na.rm = TRUE),
      current_plus_construction_mw = max(current_plus_construction_mw, na.rm = TRUE),
      total_mw = max(total_mw, na.rm = TRUE),
      .groups = "drop"
      )
# rename the 'name' column to 'county_label' to avoid analysis confusion
    county_totals <-rename(county_totals, county_label = name)
    
# Select top 20 counties by total_mw
    top20 <- county_totals |>
      arrange(desc(total_mw))|>
      slice(1:20)
  
# Reshape the data from wide to long for stacked bar charts
# We want one row per county per 'status' (current, planned, construction)
    top20_long <- top20 |>
      pivot_longer(
        cols = c(current_mw, construction_mw, planned_mw),
        names_to = "status",
        values_to = "MW"
      ) |>
      mutate( # rename the status names to make them friendly for plotting
        status = recode(status,
                        current_mw = "Current",
                        construction_mw = "Under construction",
                        planned_mw = "Planned"),
        status = factor(status, levels = c ( "Current", "Under construction", "Planned"))
        ) # reorder stack to have the legend in order of current, under construction, then planned
    ggplot(top20_long, aes( x = reorder(county_label, total_mw),
                            y = MW,
                            fill = status))+
      geom_col()+
      coord_flip()+
      geom_text(data = top20, # add data labels at the end of the stacked bars
                aes(x = reorder(county_label, total_mw),
                    y = total_mw * 1.02,
                    label = scales::comma(round(total_mw, 0))),
                inherit.aes = FALSE,
                hjust = 0,
                size = 3) +
      expand_limits( y = max(top20$total_mw, na.rm = TRUE) * 1.10)+
      labs(
        title = "Top 20 Counties by Total Data Center Energy Demand (MW)",
        x = "County",
        y = "Total energy demand (MW) \n (Stacked: current + under construction + planned)",
        fill = "Status",
        caption = "Source: National Laboratory of the Rockies Accelerating Speed to Power Data viewer"
      ) +
      theme_minimal()
