## NREL Data Analysis

```{r}
# load the libraries

library(sf) # the SF library is the modern standard library for working with spatial data. Tools include st_geometry(), st_make_valid(), st_set_precision(), st_zm()
library(tidyverse) # Core library package for data analysis in R, contains dplyr, purr, readr, tidyr, ggplot 2, tibble, stringr, and forcats
library(digest)  # hashing function: digest()...for easy comprasion and caching of data (we will use it mainly in checking for duplicates)
library(tigris) # for obtaining geographic data of the United States from the U.S. Census Bureau
```

### 1. First scrapped file (x.y.z.pfd)

```{r}
# Default web file (.x.y.z.pfd)
# load the data

baxtel_df_default <- st_read("/Users/jsupeyo/Documents/Data_Centers_Project/NREL_Data/baxtel_data_centers_by_county_default.gpkg") # default file

head(baxtel_df_default) # quick overview of the data frame


# How many rows / columns?
nrow(baxtel_df_default) # count the number of rows
ncol(baxtel_df_default) # count the number of columns
names(baxtel_df_default) # find out the column titles/ headers
baxtel_df_default <- rename(baxtel_df_default, geometry = geom) # rename the geom column to avoid naming mix up.

# Check coverage by state
baxtel_df_default |> count(state, sort = TRUE)

# Check total MW distribution
summary(baxtel_df_default$total_mw)

# Check for duplicates
  # "Exact duplicate" here means:
  #   - same IDs/attributes (gid, county info, MW columns) AND
  #   - same geometry (location/shape), detected via a geometry hash

# Why we need a geometry hash:
  #   - sf geometries can be stored in slightly different ways even if they look identical
  #   - hashing a standardized geometry gives us a stable "fingerprint" to compare

# 1) Standardize the geometry
dup_check_default <- baxtel_df_default |>
  st_zm(drop = TRUE, what = "ZM") |> 
  # Drop Z and M dimensions to avoid false differences in geometry
  st_make_valid() |> # Make good geometries valid
  st_set_precision(1e6) |> 
  # Snap coordinates to a precision grid, this treats geometries as equal when they only differ by a tiny floating point difference. 1E6 is a reasonable rounding point to start with but can be tuned further.
  
# 2) Create a geometry fingerprint (geom_hash) by converting each geometry into a binary representation
  # st_geometry(...) extracts the geometry column from the sf object
  # st_as_binary(...) converts geometry to a binary representation
  # digest(...) creates a compact hash string/ fingerprint from that binary
  # vapply is used because it is fast and enforces a character output
  mutate(
    geom_hash = vapply( 
      st_as_binary(st_geometry(baxtel_df_default |>
        st_zm(drop = TRUE, what = "ZM") |>
        st_make_valid() |>
        st_set_precision(1e6)
      )),
      digest,# hash the bytes
      FUN.VALUE = character(1), # output should be a character vector
      algo = "xxhash64" # fast hashing algorithm suitable for fingerprinting
    )
  ) |>
# 3) Check for exact duplicates (same MW + same geometry)
  count(
    gid, full_fips, name, county, state,
    current_mw, construction_mw, planned_mw,
    current_plus_construction_mw, total_mw,
    geom_hash,
    sort = TRUE
  ) |>
  filter(n > 1)

dup_check_default # view if there any duplicates

baxtel_df_default # our cleaned dataset

```

### 2. Second scrapped file, web file 12 (.12.pfd)

```{r}
# Web file 12 (.12.pfd)
# Load the data

baxtel_df_12 <- st_read("/Users/jsupeyo/Documents/Data_Centers_Project/NREL_Data/baxtel_data_centers_by_county_12.gpkg") # file 12 (Baxtel 12)

head(baxtel_df_12) # dataframe quick view

# How many rows / columns?
  nrow(baxtel_df_12)
  ncol(baxtel_df_12)
  names(baxtel_df_12)
  baxtel_df_12 <- rename(baxtel_df_12, geometry = geom) # rename the geom column to avoid syntax confusion

# Check coverage by state
  baxtel_df_12 |> count(state, sort = TRUE)

# Check total MW distribution
  summary(baxtel_df_12$total_mw)

# Check if there are any duplicates
  # 1. let's standardize the geometry
  tmp_12 <- baxtel_df_12 |>
    st_zm(drop = TRUE, what = 'ZM') |>
    st_make_valid()|>
    st_set_precision(1E6)
  
  # 2. Hash the standardized geometry
    tmp_12 <-tmp_12 |>
      mutate(
      geom_hash = vapply(
        st_as_binary(st_geometry(tmp_12)),
        digest,
        FUN.VALUE = character(1),
        algo = "xxhash64")
    )
    
  # 3. Check duplicate groups
    dup_check_12 <- tmp_12 |>
      count(
        gid, name, county, state, full_fips, current_mw, construction_mw, planned_mw, current_plus_construction_mw, total_mw, geom_hash,sort = TRUE) |>
    filter(n>1)
  
  dup_check_12 # view if there any duplicate groups

# We have 129 features on 13 fields...the two extra fields are the new geom_hash column and the n column. These are redundant columns!

# Let's remove the duplicate groups

  # number of extra rows to be removed
  sum(dup_check_12$n - 1)
  
  # largest duplicate group sizes
  dup_check_12 |>
    arrange(desc(n)) |> # arrange in descending order so the biggest duplicate counts are at the top
    select(n) |> # keep only the 'n' column...'n' is the count of rows that share the same signature in our dataset
    head(10) # display the first 10 rows of that result
  
  # remove the duplicate rows by keeping one row per signature
  baxtel_df_12_unique <- tmp_12 |>
  distinct(
    gid, name, county, state, full_fips,
    current_mw, construction_mw, planned_mw,
    current_plus_construction_mw, total_mw,
    geom_hash,
    .keep_all = TRUE
  ) |>
  select(-geom_hash) # remove the geom_hash column
  
  baxtel_df_12_unique # view the cleaned dataset for file 12
  

```

