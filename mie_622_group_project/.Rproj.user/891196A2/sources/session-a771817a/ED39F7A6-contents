#### Let's make some plots from geopackage format file.

#### i) Operational/ current energy demand per county plot

```{r}
# Let's plot a map of the operational/ current energy demand (mw) per county
    # Get the county boundaries and join our with our county total mw data
    counties <- tigris::counties(cb = TRUE, year = 2022) |> 
    mutate(full_fips = GEOID) # create a new column 'full fips' that matches our county data so we can join cleanly
    options(tigris_use_cache = TRUE) # save the shape files to a local cache for reuse (makes the script faster)
    
    county_map <- counties |>
    left_join(county_totals,
              by = "full_fips") # Attach our county mw totals to the county polygons  

    # Layer the state boundaries for state outlines
    states <- tigris::states(cb = TRUE, year = 2022) |> # check whether the states layer is using the same CRS (coordinate reference system) as the county map
    st_transform(st_crs(county_map))
    
    # plot the map showing the current/ operational energy demand for the lower 48 states
    ggplot(county_map) +
    geom_sf(aes(fill = current_mw), color = "grey70") + # counties filled
    geom_sf(data = states, fill = NA, color = "grey30", linewidth = 0.2) +  # state borders
    coord_sf(xlim = c(-125, -66), ylim = c(24, 50), expand = FALSE)+
    #coord_sf(xlim = c(-170, -60), ylim = c(18, 72), expand = FALSE) # to include Alaska and Hawaii states
    scale_fill_gradient(na.value = "grey85")+
    theme_minimal() +
    labs(title = "Operational Data Center Energy Demand by County", 
         subtitle = "Lower 48 states only (Alaska & Hawaii excluded)",
         fill = "Operating MW \n by county",
         caption = "Source: National Laboratory of the Rockies")
    
```

